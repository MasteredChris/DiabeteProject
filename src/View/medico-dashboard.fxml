<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="View.MedicoDashboardViewController">

    <!-- Header -->
    <top>
        <VBox styleClass="header">
            <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="header-bar">
                <padding>
                    <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
                </padding>

                <Label styleClass="header-title" text="Dashboard Medico">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>

                <Region HBox.hgrow="ALWAYS" />

                <!-- Alert counter badge -->
                <HBox alignment="CENTER" spacing="5.0">
                    <Button fx:id="alertButton" onAction="#showAlerts" styleClass="alert-button" text="⚠">
                        <font>
                            <Font size="14.0" />
                        </font>
                    </Button>
                    <Label fx:id="alertCountLabel" styleClass="alert-count" text="0">
                        <font>
                            <Font name="System Bold" size="12.0" />
                        </font>
                    </Label>
                </HBox>

                <Label fx:id="welcomeLabel" styleClass="welcome-label" text="Dr. [Nome Medico]">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Label>

                <Button fx:id="logoutButton" onAction="#handleLogout" styleClass="logout-button" text="Logout">
                    <font>
                        <Font size="12.0" />
                    </font>
                </Button>
            </HBox>

            <!-- Barra di navigazione -->
            <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="nav-bar">
                <padding>
                    <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
                </padding>

                <Button fx:id="dashboardTab" onAction="#showDashboard" styleClass="nav-button-active" text="Overview" />
                <Button fx:id="pazientiTab" onAction="#showPazienti" styleClass="nav-button" text="Pazienti" />
                <Button fx:id="alertTab" onAction="#showAlert" styleClass="nav-button" text="Alert" />
                <Button fx:id="statisticheTab" onAction="#showStatistiche" styleClass="nav-button" text="Statistiche" />
            </HBox>
        </VBox>
    </top>

    <!-- Contenuto principale -->
    <center>
        <StackPane fx:id="contentPane">

            <!-- Dashboard Overview -->
            <ScrollPane fx:id="dashboardPane" fitToWidth="true">
                <VBox spacing="20.0">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>

                    <!-- Cards riassuntive -->
                    <HBox spacing="20.0" styleClass="cards-container">
                        <VBox styleClass="info-card">
                            <Label styleClass="card-title" text="Pazienti Totali">
                                <font>
                                    <Font name="System Bold" size="14.0" />
                                </font>
                            </Label>
                            <Label fx:id="pazientiTotaliLabel" styleClass="card-value" text="0">
                                <font>
                                    <Font name="System Bold" size="24.0" />
                                </font>
                            </Label>
                            <Label styleClass="card-subtitle" text="in cura" />
                        </VBox>

                        <VBox styleClass="info-card alert-card">
                            <Label styleClass="card-title" text="Alert Attivi">
                                <font>
                                    <Font name="System Bold" size="14.0" />
                                </font>
                            </Label>
                            <Label fx:id="alertAttiviLabel" styleClass="card-value" text="0">
                                <font>
                                    <Font name="System Bold" size="24.0" />
                                </font>
                            </Label>
                            <Label styleClass="card-subtitle" text="non visualizzati" />
                        </VBox>

                        <VBox styleClass="info-card">
                            <Label styleClass="card-title" text="Terapie Attive">
                                <font>
                                    <Font name="System Bold" size="14.0" />
                                </font>
                            </Label>
                            <Label fx:id="terapieAttiveLabel" styleClass="card-value" text="0">
                                <font>
                                    <Font name="System Bold" size="24.0" />
                                </font>
                            </Label>
                            <Label styleClass="card-subtitle" text="prescrizioni" />
                        </VBox>

                        <VBox styleClass="info-card">
                            <Label styleClass="card-title" text="Rilevazioni Oggi">
                                <font>
                                    <Font name="System Bold" size="14.0" />
                                </font>
                            </Label>
                            <Label fx:id="rilevazioniOggiLabel" styleClass="card-value" text="0">
                                <font>
                                    <Font name="System Bold" size="24.0" />
                                </font>
                            </Label>
                            <Label styleClass="card-subtitle" text="registrate" />
                        </VBox>
                    </HBox>

                    <!-- Alert urgenti -->
                    <VBox fx:id="alertUrgentiSection" spacing="10.0" styleClass="urgent-alerts">
                        <Label styleClass="section-title alert-title" text="⚠ Alert Urgenti">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                        <ListView fx:id="alertUrgentiList" maxHeight="120.0" styleClass="urgent-alerts-list" />
                    </VBox>

                    <!-- Grafici overview -->
                    <HBox spacing="20.0">
                        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                            <Label styleClass="section-subtitle" text="Distribuzione Alert">
                                <font>
                                    <Font name="System Bold" size="14.0" />
                                </font>
                            </Label>
                            <PieChart fx:id="alertDistribuzioneChart" prefHeight="200.0" />
                        </VBox>

                        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                            <Label styleClass="section-subtitle" text="Rilevazioni Settimanali">
                                <font>
                                    <Font name="System Bold" size="14.0" />
                                </font>
                            </Label>
                            <LineChart fx:id="rilevazioniSettimanaliChart" prefHeight="200.0">
                                <xAxis>
                                    <CategoryAxis side="BOTTOM" />
                                </xAxis>
                                <yAxis>
                                    <NumberAxis side="LEFT" />
                                </yAxis>
                            </LineChart>
                        </VBox>
                    </HBox>
                </VBox>
            </ScrollPane>

            <!-- Sezione Pazienti -->
            <VBox fx:id="pazientiPane" spacing="15.0" visible="false">
                <padding>
                    <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                </padding>

                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <Label styleClass="section-title" text="I Miei Pazienti">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font>
                    </Label>
                    <Region HBox.hgrow="ALWAYS" />
                    <TextField fx:id="searchPazienteField" promptText="Cerca paziente..." styleClass="search-field" />
                    <Button onAction="#handleSearchPaziente" styleClass="secondary-button" text="Cerca" />
                </HBox>

                <!-- Tabella pazienti -->
                <TableView fx:id="pazientiTable" styleClass="data-table">
                    <columns>
                        <TableColumn fx:id="colNomePaz" prefWidth="120.0" text="Nome" />
                        <TableColumn fx:id="colCognomePaz" prefWidth="120.0" text="Cognome" />
                        <TableColumn fx:id="colEmailPaz" prefWidth="180.0" text="Email" />
                        <TableColumn fx:id="colUltimaRilevazionePaz" prefWidth="130.0" text="Ultima Rilevazione" />
                        <TableColumn fx:id="colStatoPaz" prefWidth="100.0" text="Stato" />
                        <TableColumn fx:id="colTerapieAttivePaz" prefWidth="80.0" text="Terapie" />
                        <TableColumn fx:id="colAzioniPaz" prefWidth="200.0" text="Azioni" />
                    </columns>
                </TableView>

                <!-- Dettagli paziente selezionato -->
                <VBox fx:id="dettagliPazientePane" spacing="10.0" styleClass="patient-details" visible="false">
                    <Label styleClass="section-subtitle" text="Dettagli Paziente">
                        <font>
                            <Font name="System Bold" size="14.0" />
                        </font>
                    </Label>

                    <GridPane hgap="15.0" vgap="10.0">
                        <columnConstraints>
                            <ColumnConstraints hgrow="NEVER" minWidth="120.0" />
                            <ColumnConstraints hgrow="ALWAYS" />
                            <ColumnConstraints hgrow="NEVER" minWidth="120.0" />
                            <ColumnConstraints hgrow="ALWAYS" />
                        </columnConstraints>

                        <Label text="Nome Completo:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <Label fx:id="dettaglioNomeLabel" text="--" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                        <Label text="Email:" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                        <Label fx:id="dettaglioEmailLabel" text="--" GridPane.columnIndex="3" GridPane.rowIndex="0" />

                        <Label text="Fattori di Rischio:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <Label fx:id="dettaglioFattoriLabel" text="--" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                        <Label text="Comorbidità:" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                        <Label fx:id="dettaglioComorbidita" text="--" wrapText="true" GridPane.columnIndex="3" GridPane.rowIndex="1" />
                    </GridPane>

                    <!-- Grafico glicemie paziente -->
                    <VBox spacing="10.0">
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Label styleClass="chart-title" text="Andamento Glicemie">
                                <font>
                                    <Font name="System Bold" size="12.0" />
                                </font>
                            </Label>
                            <ComboBox fx:id="periodoChart" promptText="Seleziona periodo">
                                <items>
                                    <FXCollections fx:factory="observableArrayList">
                                        <String fx:value="7 giorni" />
                                        <String fx:value="30 giorni" />
                                        <String fx:value="3 mesi" />
                                    </FXCollections>
                                </items>
                            </ComboBox>
                            <Button onAction="#aggiornaGraficoPaziente" styleClass="secondary-button" text="Aggiorna" />
                        </HBox>
                        <LineChart fx:id="glicemiaPazienteChart" prefHeight="200.0">
                            <xAxis>
                                <CategoryAxis side="BOTTOM" />
                            </xAxis>
                            <yAxis>
                                <NumberAxis side="LEFT" />
                            </yAxis>
                        </LineChart>
                    </VBox>

                    <!-- Azioni paziente -->
                    <HBox spacing="10.0">
                        <Button onAction="#handlePrescriviTerapia" styleClass="primary-button" text="Prescrivi Terapia" />
                        <Button onAction="#handleModificaTerapia" styleClass="secondary-button" text="Modifica Terapia" />
                        <Button onAction="#handleVisualizzaStoria" styleClass="secondary-button" text="Storia Clinica" />
                        <Button onAction="#handleInviaMessaggio" styleClass="secondary-button" text="Invia Messaggio" />
                    </HBox>
                </VBox>
            </VBox>

            <!-- Sezione Alert -->
            <VBox fx:id="alertPane" spacing="15.0" visible="false">
                <padding>
                    <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                </padding>

                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <Label styleClass="section-title" text="Gestione Alert">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font>
                    </Label>
                    <Region HBox.hgrow="ALWAYS" />
                    <ComboBox fx:id="filtroUrgenzaAlert" promptText="Filtra per urgenza">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="Tutti" />
                                <String fx:value="URGENTE" />
                                <String fx:value="ATTENZIONE" />
                                <String fx:value="NORMALE" />
                            </FXCollections>
                        </items>
                    </ComboBox>
                    <CheckBox fx:id="soloNonVisualizzati" text="Solo non visualizzati" />
                    <Button onAction="#handleFiltraAlert" styleClass="secondary-button" text="Filtra" />
                </HBox>

                <!-- Tabella alert -->
                <TableView fx:id="alertTable" styleClass="data-table">
                    <columns>
                        <TableColumn fx:id="colDataAlert" prefWidth="130.0" text="Data/Ora" />
                        <TableColumn fx:id="colPazienteAlert" prefWidth="150.0" text="Paziente" />
                        <TableColumn fx:id="colTipoAlert" prefWidth="130.0" text="Tipo" />
                        <TableColumn fx:id="colUrgenzaAlert" prefWidth="100.0" text="Urgenza" />
                        <TableColumn fx:id="colMessaggioAlert" prefWidth="300.0" text="Messaggio" />
                        <TableColumn fx:id="colStatoAlert" prefWidth="80.0" text="Stato" />
                        <TableColumn fx:id="colAzioniAlert" prefWidth="120.0" text="Azioni" />
                    </columns>
                </TableView>
            </VBox>

            <!-- Sezione Statistiche -->
            <ScrollPane fx:id="statistichePane" fitToWidth="true" visible="false">
                <VBox spacing="20.0">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>

                    <Label styleClass="section-title" text="Statistiche Generali">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font>
                    </Label>

                    <!-- Periodo analisi -->
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <Label text="Periodo di analisi:" />
                        <ComboBox fx:id="periodoAnalisi" value="Ultimo mese">
                            <items>
                                <FXCollections fx:factory="observableArrayList">
                                    <String fx:value="Ultima settimana" />
                                    <String fx:value="Ultimo mese" />
                                    <String fx:value="Ultimi 3 mesi" />
                                    <String fx:value="Ultimo anno" />
                                </FXCollections>
                            </items>
                        </ComboBox>
                        <Button onAction="#aggiornaStatistiche" styleClass="primary-button" text="Aggiorna" />
                    </HBox>

                    <!-- Grafici statistiche -->
                    <HBox spacing="20.0">
                        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                            <Label styleClass="section-subtitle" text="Distribuzione Glicemie per Range">
                                <font>
                                    <Font name="System Bold" size="14.0" />
                                </font>
                            </Label>
                            <PieChart fx:id="glicemieRangeChart" prefHeight="300.0" />
                        </VBox>

                        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                            <Label styleClass="section-subtitle" text="Aderenza Terapeutica Media">
                                <font>
                                    <Font name="System Bold" size="14.0" />
                                </font>
                            </Label>
                            <BarChart fx:id="aderenzaTerapeuticaChart" prefHeight="300.0">
                                <xAxis>
                                    <CategoryAxis side="BOTTOM" />
                                </xAxis>
                                <yAxis>
                                    <NumberAxis side="LEFT" />
                                </yAxis>
                            </BarChart>
                        </VBox>
                    </HBox>

                    <!-- Tabella riassuntiva -->
                    <VBox spacing="10.0">
                        <Label styleClass="section-subtitle" text="Riepilogo Pazienti">
                            <font>
                                <Font name="System Bold" size="14.0" />
                            </font>
                        </Label>
                        <TableView fx:id="riepilogatoPazientiTable" maxHeight="200.0" styleClass="stats-table">
                            <columns>
                                <TableColumn fx:id="colPazienteStat" prefWidth="150.0" text="Paziente" />
                                <TableColumn fx:id="colRilevazioniStat" prefWidth="100.0" text="Rilevazioni" />
                                <TableColumn fx:id="colMediaGlicemiaStat" prefWidth="120.0" text="Media Glicemia" />
                                <TableColumn fx:id="colAderenzaStat" prefWidth="100.0" text="Aderenza" />
                                <TableColumn fx:id="colAlertStat" prefWidth="80.0" text="Alert" />
                                <TableColumn fx:id="colUltimoAccessoStat" prefWidth="130.0" text="Ultimo Accesso" />
                            </columns>
                        </TableView>
                    </VBox>
                </VBox>
            </ScrollPane>

        </StackPane>
    </center>

    <!-- Barra di stato -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="status-bar">
            <padding>
                <Insets bottom="5.0" left="15.0" right="15.0" top="5.0" />
            </padding>

            <Label fx:id="statusLabel" styleClass="status-text" text="Pronto">
                <font>
                    <Font size="11.0" />
                </font>
            </Label>

            <Region HBox.hgrow="ALWAYS" />

            <Label fx:id="lastUpdateLabel" styleClass="status-text" text="Ultimo aggiornamento: --">
                <font>
                    <Font size="11.0" />
                </font>
            </Label>
        </HBox>
    </bottom>

</BorderPane>